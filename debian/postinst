#!/bin/bash
set -e

APP_DIR="/usr/lib/ups-pi-node"
VAR_DIR="/var/lib/ups-pi-node"
CONF_DIR="/etc/ups-pi-node"
ENV_FILE="/etc/default/ups-pi-node"
VENV_DIR="$VAR_DIR/.venv"
WIDGETS_DIR="$VAR_DIR/widgets"
DASHBOARD_WIDGETS_FILE="$VAR_DIR/dashboard-widgets.json"

case "$1" in
    configure)
        mkdir -p "$CONF_DIR"
        mkdir -p "$WIDGETS_DIR"

        if [ ! -f "$ENV_FILE" ]; then
            secret_key="$(python3 -c 'import secrets; print(secrets.token_urlsafe(48))')"
            old_umask="$(umask)"
            umask 077
            {
                printf 'UPS_PI_NODE_SECRET_KEY=%s\n' "$secret_key"
                printf 'UPS_PI_NODE_CONFIG_FILE=%s/main.conf\n' "$CONF_DIR"
                printf 'UPS_PI_NODE_WIDGETS_DIR=%s\n' "$WIDGETS_DIR"
                printf 'UPS_PI_NODE_DASHBOARD_WIDGETS_FILE=%s\n' "$DASHBOARD_WIDGETS_FILE"
            } > "$ENV_FILE"
            umask "$old_umask"
            chown root:www-data "$ENV_FILE"
            chmod 640 "$ENV_FILE"
            echo "Created environment file: $ENV_FILE"
        fi

        if [ ! -f "$CONF_DIR/main.conf" ]; then
            cp "$CONF_DIR/main.conf.example" "$CONF_DIR/main.conf"
            chmod 660 "$CONF_DIR/main.conf"
            echo "Created config: $CONF_DIR/main.conf"
        fi

        if [ ! -d "$VENV_DIR" ]; then
            python3 -m venv --system-site-packages "$VENV_DIR"
        elif [ -f "$VENV_DIR/pyvenv.cfg" ]; then
            if grep -q '^include-system-site-packages = ' "$VENV_DIR/pyvenv.cfg"; then
                sed -i 's/^include-system-site-packages = .*/include-system-site-packages = true/' "$VENV_DIR/pyvenv.cfg"
            else
                printf '\ninclude-system-site-packages = true\n' >> "$VENV_DIR/pyvenv.cfg"
            fi
        fi
        "$VENV_DIR/bin/pip" install --quiet -r "$APP_DIR/requirements.txt"

        chown -R root:root "$APP_DIR"
        find "$APP_DIR" -type d -exec chmod 755 {} +
        find "$APP_DIR" -type f -exec chmod 644 {} +
        chown -R www-data:www-data "$VAR_DIR"
        chmod 750 "$VAR_DIR" "$WIDGETS_DIR"
        chown root:www-data "$CONF_DIR/main.conf"
        chmod 660 "$CONF_DIR/main.conf"

        chmod +x /usr/bin/ups-pi-node-hotspot-fallback

        if [ -f /etc/nginx/sites-enabled/default ]; then
            rm -f /etc/nginx/sites-enabled/default
        fi
        ln -sf /etc/nginx/sites-available/ups-pi-node \
               /etc/nginx/sites-enabled/ups-pi-node

        systemctl daemon-reload
        systemctl enable ups-pi-node-helper.service
        systemctl enable ups-pi-node.service
        systemctl enable ups-pi-node-hotspot-fallback.timer
        systemctl restart ups-pi-node-helper.service
        systemctl restart ups-pi-node.service
        systemctl restart ups-pi-node-hotspot-fallback.timer
        systemctl reload nginx || true
        ;;
esac

exit 0
